# Redis Cloud connection (AWS EC2 / Redis Cloud)
REDIS_HOST=your-redis-host.ec2.redns.redis-cloud.com
REDIS_PORT=your-port
REDIS_USERNAME=default
REDIS_PWD=your-redis-password

# Path to uv executable (for Redis MCP server startup)
UV_PATH=C:/path/to/uv.exe

# Path to the Redis MCP server directory
REDIS_MCP_DIR=path/to/mcp-redis

# Path to the MongoDB MCP server script
MONGO_MCP_PATH=path/to/ClaudeClient/main.py

# OpenAI API key (for GPT-4o model in agents)
OPENAI_API_KEY=sk-...

# Google API key (for Gemini models)
GOOGLE_API_KEY=your-google-api-key

# Tavily search API
TAVILY_API_KEY=tvly-...

# SerpAPI key (for Google Finance agent)
SERP_API_KEY=your-serp-api-key

# Microsoft 365 OAuth (Client ID only — never commit client secret)
CLIENT_ID=your-azure-app-client-id
